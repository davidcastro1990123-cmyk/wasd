local function CreateRing(color)
	local part = Instance.new("Part", workspace)
	part.Shape = "Cylinder"; part.Material = "ForceField"; part.Color = color
	part.Transparency = 1; part.CanCollide = false; part.Anchored = true; part.Size = Vector3.new(0.1, 0, 0)
	return part
end
