-- CORE LOGIC LOOP
-------------------------------------------------------------------------
RunService.Heartbeat:Connect(function()
	local Char = LocalPlayer.Character
	if not Char or not Char:FindFirstChild("HumanoidRootPart") then return end
	local HRP = Char.HumanoidRootPart
	local Hum = Char:FindFirstChild("Humanoid")

	-- 1. Anti Ragdoll
	if Flags.AntiRagdoll then
		Hum:SetStateEnabled(Enum.HumanoidStateType.Ragdoll, false)
		Hum:SetStateEnabled(Enum.HumanoidStateType.FallingDown, false)
	end

	-- 2. Helicopter (Spin)
	if Flags.Helicopter then
		HRP.CFrame = HRP.CFrame * CFrame.Angles(0, math.rad(Flags.HeliSpeed), 0)
	end

	-- 3. Visual Rings
	GrabRing.CFrame = HRP.CFrame * CFrame.new(0, -2.8, 0) * CFrame.Angles(0,0,math.rad(90))
	GrabRing.Size = Vector3.new(0.1, Flags.GrabRadius * 2, Flags.GrabRadius * 2)
	GrabRing.Transparency = Flags.AutoGrab and 0.4 or 1

	HitRing.CFrame = HRP.CFrame * CFrame.new(0, -2.8, 0) * CFrame.Angles(0,0,math.rad(90))
	HitRing.Size = Vector3.new(0.1, 12, 12)
	HitRing.Transparency = Flags.HitCircle and 0.6 or 1

	-- 4. Auto Grab Logic (Brainrot Pickup)
	if Flags.AutoGrab then
		for _, item in pairs(workspace:GetChildren()) do
			if item.Name == "Brainrot" and item:IsA("BasePart") then
				if (item.Position - HRP.Position).Magnitude <= Flags.GrabRadius then
					firetouchinterest(HRP, item, 0)
					firetouchinterest(HRP, item, 1)
				end
			end
		end
	end

	-- 5. Spam Bat & Bat Aimbot
	if Flags.SpamBat or Flags.BatAimbot then
		local Bat = Char:FindFirstChild("Bat") or LocalPlayer.Backpack:FindFirstChild("Bat")
		if Bat then
			Bat.Parent = Char
			if Flags.SpamBat then Bat:Activate() end
			if Flags.BatAimbot then
				local target = nil; local dist = 25
				for _, p in pairs(Players:GetPlayers()) do
					if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
						local d = (p.Character.HumanoidRootPart.Position - HRP.Position).Magnitude
						if d < dist then dist = d; target = p.Character.HumanoidRootPart end
					end
				end
				if target then HRP.CFrame = CFrame.new(HRP.Position, Vector3.new(target.Position.X, HRP.Position.Y, target.Position.Z)) end
			end
		end
	end

	-- 6. Environment / Character Modifiers
	Hum.WalkSpeed = Flags.SpeedValue
	workspace.Gravity = Flags.Gravity and 80 or 196.2
	Char.Animate.Disabled = Flags.Unwalk
	if Flags.XRay then
		for _, part in pairs(workspace:GetDescendants()) do
			if part:IsA("BasePart") and part.Name == "Base" then part.Transparency = 0.5 end
		end
	end
end)

