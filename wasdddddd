-- 3. WIN NOTIFICATION FUNCTION (Matching your image)
local function ShowWinMessage(username)
    local WinLabel = Instance.new("TextLabel")
    WinLabel.Parent = ScreenGui
    WinLabel.BackgroundTransparency = 1
    WinLabel.Position = UDim2.new(0.5, -200, 0.7, 0)
    WinLabel.Size = UDim2.new(0, 400, 0, 50)
    WinLabel.Font = Enum.Font.GothamBold
    WinLabel.Text = "@" .. username .. " won the duel!"
    WinLabel.TextSize = 35
    
    -- Blue/White Stroke effect from image
    local Stroke = Instance.new("UIStroke")
    Stroke.Parent = WinLabel
    Stroke.Thickness = 3
    Stroke.Color = Color3.fromRGB(0, 0, 0)
    
    WinLabel.TextColor3 = Color3.fromRGB(80, 180, 255) -- Blue text
    
    -- Fade out and disappear
    task.wait(3)
    for i = 0, 1, 0.1 do
        WinLabel.TextTransparency = i
        Stroke.Transparency = i
        task.wait(0.05)
    end
    WinLabel:Destroy()
end

-- 4. BUTTON GENERATOR
local function CreateButton(name, defaultText)
    local Button = Instance.new("TextButton")
    local ButtonCorner = Instance.new("UICorner")
    local Stroke = Instance.new("UIStroke")
    
    Button.Name = name
    Button.Parent = MainFrame
    Button.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    Button.Size = UDim2.new(0, 190, 0, 55)
    Button.Font = Enum.Font.GothamBold
    Button.Text = defaultText .. " OFF"
    Button.TextColor3 = Color3.fromRGB(255, 255, 255)
    Button.TextSize = 16
    
    ButtonCorner.CornerRadius = UDim.new(0, 12)
    ButtonCorner.Parent = Button
    
    Stroke.Parent = Button
    Stroke.Thickness = 2
    Stroke.Color = Color3.fromRGB(140, 60, 255)
    
    local toggled = false
    Button.MouseButton1Click:Connect(function()
        toggled = not toggled
        if toggled then
            Button.BackgroundColor3 = Color3.fromRGB(140, 60, 255)
            Button.Text = defaultText .. " ON"
            
            -- Example: Triggering the win message when you enable a button
            if name == "AutoGrab" then
                ShowWinMessage(game.Players.LocalPlayer.Name)
            end
        else
            Button.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
            Button.Text = defaultText .. " OFF"
        end
    end)
end

-- Create the buttons
CreateButton("AutoLeft", "Auto Left")
